# Running Performance Analyzer - Environment Variables Template
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual credentials (never commit .env to git!)
# 3. Restart Docker containers after modifying .env

# =============================================================================
# GARMIN CONNECT API
# =============================================================================
# Your Garmin Connect credentials
# Documentation: https://github.com/cyberjunky/python-garminconnect
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_garmin_password

# Optional: Garmin session persistence (avoid re-login)
# If true, session tokens are saved locally
GARMIN_SAVE_SESSION=true

# =============================================================================
# STRAVA API (Optional - if you want to sync Strava data)
# =============================================================================
# Get your API credentials at: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REFRESH_TOKEN=your_refresh_token

# =============================================================================
# CLAUDE API (Anthropic)
# =============================================================================
# For AI Coach functionality
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (claude-sonnet-4-20250514 recommended for cost/performance balance)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# DUCKDB CONFIGURATION
# =============================================================================
# Path to DuckDB database file
DUCKDB_PATH=data/duckdb/running_analytics.duckdb

# =============================================================================
# AIRFLOW CONFIGURATION
# =============================================================================
# Airflow admin user credentials
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin_secure_password_change_me
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Airflow executor (LocalExecutor recommended for single-machine)
AIRFLOW_EXECUTOR=LocalExecutor

# Airflow Fernet key for encrypting secrets (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW_FERNET_KEY=your_fernet_key_here

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment (development, staging, production)
ENVIRONMENT=development

# Enable debug mode (verbose logging)
DEBUG=true

# Timezone for dates/times display
TIMEZONE=Europe/Paris

# =============================================================================
# DATA SYNC CONFIGURATION
# =============================================================================
# How many days of historical data to fetch on first sync
INITIAL_SYNC_DAYS=365

# Daily sync - how many days to look back (to catch late updates)
DAILY_SYNC_DAYS=7

# =============================================================================
# RUNNER PROFILE (Optional - for AI personalization)
# =============================================================================
# Your runner profile info (used by AI Coach for better recommendations)
RUNNER_AGE=35
RUNNER_WEIGHT_KG=70
RUNNER_HEIGHT_CM=175
RUNNER_GENDER=M
RUNNER_EXPERIENCE_YEARS=5

# Max heart rate (if known, otherwise calculated from age)
# Formula: 220 - age
RUNNER_MAX_HR=185

# =============================================================================
# STREAMLIT CONFIGURATION
# =============================================================================
# Port for Streamlit app
STREAMLIT_PORT=8501

# =============================================================================
# BACKUP & RETENTION
# =============================================================================
# Number of days to keep raw API responses (0 = keep forever)
RAW_DATA_RETENTION_DAYS=90

# Enable automatic backups of DuckDB
ENABLE_AUTO_BACKUP=true
BACKUP_FREQUENCY_DAYS=7

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================
# Apple Health (if you export Apple Health data manually)
# Path to Apple Health export.xml
APPLE_HEALTH_EXPORT_PATH=

# Notion (if you want to sync data to Notion)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Google Sheets (if you want to export data to Google Sheets)
GOOGLE_SHEETS_CREDENTIALS_PATH=

# =============================================================================
# ADVANCED - LLM CONFIGURATION
# =============================================================================
# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3

# Max tokens for LLM responses
LLM_MAX_TOKENS=2000

# Enable RAG (Retrieval Augmented Generation) for running knowledge base
ENABLE_RAG=false

# Vector store for RAG (if enabled)
RAG_VECTOR_STORE_PATH=ai_engine/rag/vector_store

# =============================================================================
# MONITORING & ALERTS (Future - optional)
# =============================================================================
# Email notifications for pipeline failures
ALERT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Slack webhook for notifications
SLACK_WEBHOOK_URL=

# =============================================================================
# NOTES
# =============================================================================
# - Never commit .env to version control
# - Use strong passwords for Airflow admin
# - Rotate API keys regularly
# - Keep ANTHROPIC_API_KEY secure (has billing implications)
