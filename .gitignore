# Running Performance Analyzer - .gitignore

# =============================================================================
# CREDENTIALS & SECRETS - NEVER COMMIT THESE
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets/
config/secrets.yml

# Garmin/Strava API tokens
garmin_session.json
strava_tokens.json

# =============================================================================
# PYTHON
# =============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.log

# =============================================================================
# JUPYTER NOTEBOOKS
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# Jupyter Notebook metadata
.ipynb

# =============================================================================
# DATA FILES - DO NOT COMMIT RAW/SENSITIVE DATA
# =============================================================================
# Raw data from APIs (contains personal health data)
data/raw/**
!data/raw/.gitkeep

# Exports
data/exports/**
!data/exports/.gitkeep

# DuckDB write-ahead log and temp files
*.duckdb.wal
*.duckdb.tmp

# Large data files
*.csv
*.xlsx
*.parquet
*.json
!dbt_project/seeds/*.csv  # Exception: seed files are OK

# =============================================================================
# DBT
# =============================================================================
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
dbt_project/dbt_modules/

# =============================================================================
# AIRFLOW
# =============================================================================
airflow/logs/**
!airflow/logs/.gitkeep
airflow/airflow.db
airflow/airflow.cfg
airflow/webserver_config.py
airflow/unittests.cfg
airflow/*.pid

# =============================================================================
# STREAMLIT
# =============================================================================
.streamlit/secrets.toml

# =============================================================================
# IDE / EDITORS
# =============================================================================
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# =============================================================================
# OS SPECIFIC
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# =============================================================================
# DOCKER
# =============================================================================
# Docker volumes data (except DuckDB which we might want to track initially)
docker-volumes/**
!docker-volumes/.gitkeep

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
*.out

# =============================================================================
# TEMPORARY FILES
# =============================================================================
tmp/
temp/
*.tmp
*.bak
*.swp

# =============================================================================
# AI / ML
# =============================================================================
# Vector stores (if using RAG)
ai_engine/rag/vector_store/**
!ai_engine/rag/vector_store/.gitkeep

# Model files (if downloading models locally)
*.pt
*.pth
*.ckpt
*.h5
*.pkl
*.joblib

# =============================================================================
# DOCUMENTATION BUILD
# =============================================================================
docs/_build/
site/

# =============================================================================
# MISC
# =============================================================================
.cache/
*.pid
*.seed
*.pid.lock

# =============================================================================
# EXCEPTIONS - FILES TO KEEP
# =============================================================================
# Keep example/template files
!.env.example
!docker-compose.example.yml

# Keep .gitkeep files to preserve empty directory structure
!.gitkeep

# Keep seed data for dbt
!dbt_project/seeds/*.csv

# Keep the main DuckDB file (small, useful to track schema evolution)
# Comment this line if DB becomes too large
!data/duckdb/running_analytics.duckdb